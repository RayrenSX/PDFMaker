@echo off
chcp 65001 >nul
title PDFMaker Installer

net session >nul 2>&1
if %errorlevel% neq 0 (
    powershell -Command "Start-Process '%~f0' -Verb RunAs"
    exit
)

echo ==========================
echo PDFMaker Installer
echo ==========================

set "INSTALL=C:\PDFMaker"

if not exist "%INSTALL%" mkdir "%INSTALL%"

echo Installing core files...

powershell -NoProfile -Command "[IO.File]::WriteAllBytes('C:\PDFMaker\图片转PDF.ps1',[Convert]::FromBase64String(''))"

powershell -NoProfile -Command "[IO.File]::WriteAllBytes('C:\PDFMaker\图片转PDF.bat',[Convert]::FromBase64String(''))"

echo Checking Chocolatey...

where choco >nul 2>&1
if errorlevel 1 (
    echo Installing Chocolatey...
    powershell -NoProfile -ExecutionPolicy Bypass -Command "Set-ExecutionPolicy Bypass -Scope Process -Force; iex ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))"
)

echo Installing ImageMagick...
choco install imagemagick -y

echo Installing 7-Zip...
choco install 7zip -y

echo Creating desktop shortcut...

powershell -NoProfile -Command "$s=(New-Object -ComObject WScript.Shell).CreateShortcut([Environment]::GetFolderPath('Desktop')+'\PDFMaker.lnk');$s.TargetPath='C:\PDFMaker\图片转PDF.bat';$s.WorkingDirectory='C:\PDFMaker';$s.Save()"

echo.
echo ==========================
echo Installation Complete
echo ==========================
echo Location: C:\PDFMaker
echo Shortcut: Desktop\PDFMaker.lnk

pause
